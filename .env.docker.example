ADMIN_PASSWORD=admin
ZEN_HOST=opencode.ai
ZEN_PATH=/zen/v1/chat/completions
UPSTREAM_TIMEOUT_MS=120000
GLOBAL_REQUESTS_PER_MINUTE=120
API_KEY_REQUESTS_PER_MINUTE=60
API_KEY_MAX_CONCURRENT_REQUESTS=10
API_KEY_MAX_CONCURRENT_STREAMS=5
REDIS_KEY_PREFIX=opencode-proxy-hub:limit
SHUTDOWN_DRAIN_TIMEOUT_MS=30000
STORE_PLAINTEXT_API_KEYS=true
OUTBOUND_PRE_PROXY_ENABLED=false
OUTBOUND_PRE_PROXY_URL=http://host.docker.internal:7897
REQUIRE_PROXY=false
