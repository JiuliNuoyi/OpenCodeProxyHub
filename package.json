{
  "name": "opencode-proxy-hub",
  "version": "0.1.0",
  "description": "OpenAI and Anthropic compatible gateway for OpenCode free models",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:web": "npm --prefix web run dev",
    "start": "node dist/main.js",
    "build": "tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "build:all": "npm run build && npm run build:web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke:protocol": "node scripts/protocol-smoke.mjs",
    "smoke:load": "node scripts/load-smoke.mjs",
    "check:stability": "node scripts/stability-check.mjs"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "https-proxy-agent": "^7.0.6",
    "redis": "^5.12.1",
    "socks-proxy-agent": "^8.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
